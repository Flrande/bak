{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bak.local/schemas/protocol.json",
  "title": "Browser Agent Kit Protocol",
  "type": "object",
  "definitions": {
    "jsonRpcRequest": {
      "type": "object",
      "required": ["jsonrpc", "method"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": {
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "null" }]
        },
        "method": {
          "type": "string",
          "enum": [
            "session.create",
            "session.close",
            "session.info",
            "tabs.list",
            "tabs.focus",
            "tabs.new",
            "tabs.close",
            "tabs.getActive",
            "tabs.get",
            "page.goto",
            "page.back",
            "page.forward",
            "page.reload",
            "page.wait",
            "page.snapshot",
            "page.title",
            "page.url",
            "page.text",
            "page.dom",
            "page.accessibilityTree",
            "page.scrollTo",
            "page.viewport",
            "page.metrics",
            "element.click",
            "element.type",
            "element.scroll",
            "element.hover",
            "element.doubleClick",
            "element.rightClick",
            "element.dragDrop",
            "element.select",
            "element.check",
            "element.uncheck",
            "element.scrollIntoView",
            "element.focus",
            "element.blur",
            "element.get",
            "keyboard.press",
            "keyboard.type",
            "keyboard.hotkey",
            "mouse.move",
            "mouse.click",
            "mouse.wheel",
            "file.upload",
            "context.enterFrame",
            "context.exitFrame",
            "context.enterShadow",
            "context.exitShadow",
            "context.reset",
            "network.list",
            "network.get",
            "network.waitFor",
            "network.clear",
            "debug.getConsole",
            "debug.dumpState"
          ]
        },
        "params": {}
      },
      "additionalProperties": false
    },
    "jsonRpcSuccess": {
      "type": "object",
      "required": ["jsonrpc", "id", "result"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": {
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "null" }]
        },
        "result": {}
      },
      "additionalProperties": false
    },
    "jsonRpcFailure": {
      "type": "object",
      "required": ["jsonrpc", "id", "error"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": {
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "null" }]
        },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "number" },
            "message": { "type": "string" },
            "data": {
              "type": "object",
              "properties": {
                "bakCode": {
                  "type": "string",
                  "enum": [
                    "E_NOT_PAIRED",
                    "E_PERMISSION",
                    "E_NOT_FOUND",
                    "E_NEED_USER_CONFIRM",
                    "E_TIMEOUT",
                    "E_INVALID_PARAMS",
                    "E_INTERNAL",
                    "E_NOT_READY"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "locator": {
      "type": "object",
      "properties": {
        "eid": { "type": "string" },
        "role": { "type": "string" },
        "name": { "type": "string" },
        "text": { "type": "string" },
        "css": { "type": "string" },
        "framePath": {
          "type": "array",
          "items": { "type": "string" }
        },
        "shadow": {
          "type": "string",
          "enum": ["auto", "pierce", "none"]
        },
        "index": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "elementMapItem": {
      "type": "object",
      "required": ["eid", "tag", "role", "name", "text", "bbox", "selectors", "risk"],
      "properties": {
        "eid": { "type": "string" },
        "tag": { "type": "string" },
        "role": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "text": { "type": "string" },
        "bbox": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        "selectors": {
          "type": "object",
          "required": ["css", "text", "aria"],
          "properties": {
            "css": { "type": ["string", "null"] },
            "text": { "type": ["string", "null"] },
            "aria": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "risk": { "type": "string", "enum": ["low", "high"] }
      },
      "additionalProperties": false
    },
    "sessionInfoResult": {
      "type": "object",
      "required": [
        "sessionId",
        "paired",
        "extensionConnected",
        "connectionState",
        "connectionReason",
        "protocolVersion",
        "compatibleProtocolVersions",
        "extensionVersion",
        "activeTab",
        "context",
        "heartbeatStale",
        "heartbeatAgeMs",
        "staleAfterMs",
        "lastSeenTs",
        "lastHeartbeatTs",
        "bridgePendingRequests",
        "bridgeLastError",
        "bridgeTotalRequests",
        "bridgeTotalFailures",
        "bridgeTotalTimeouts",
        "bridgeTotalNotReady",
        "capabilityCount"
      ],
      "properties": {
        "sessionId": { "type": ["string", "null"] },
        "paired": { "type": "boolean" },
        "extensionConnected": { "type": "boolean" },
        "connectionState": { "type": "string", "enum": ["connecting", "connected", "disconnected"] },
        "connectionReason": { "type": ["string", "null"] },
        "protocolVersion": { "type": "string", "const": "v4" },
        "compatibleProtocolVersions": {
          "type": "array",
          "items": { "type": "string", "enum": ["v4"] }
        },
        "extensionVersion": { "type": ["string", "null"] },
        "activeTab": {
          "type": ["object", "null"],
          "required": ["id", "title", "url"],
          "properties": {
            "id": { "type": "number" },
            "title": { "type": "string" },
            "url": { "type": "string" }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["frameDepth", "shadowDepth"],
          "properties": {
            "frameDepth": { "type": "number" },
            "shadowDepth": { "type": "number" }
          },
          "additionalProperties": false
        },
        "heartbeatStale": { "type": "boolean" },
        "heartbeatAgeMs": { "type": ["number", "null"] },
        "staleAfterMs": { "type": "number" },
        "lastSeenTs": { "type": ["number", "null"] },
        "lastHeartbeatTs": { "type": ["number", "null"] },
        "bridgePendingRequests": { "type": "number" },
        "bridgeLastError": { "type": ["string", "null"] },
        "bridgeTotalRequests": { "type": "number" },
        "bridgeTotalFailures": { "type": "number" },
        "bridgeTotalTimeouts": { "type": "number" },
        "bridgeTotalNotReady": { "type": "number" },
        "capabilityCount": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/jsonRpcRequest" },
    { "$ref": "#/definitions/jsonRpcSuccess" },
    { "$ref": "#/definitions/jsonRpcFailure" }
  ]
}
