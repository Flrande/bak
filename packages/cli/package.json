{
  "name": "@flrande/bak-cli",
  "version": "0.4.0",
  "type": "module",
  "bin": {
    "bak": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsup src/bin.ts src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/bin.ts serve --port 17373",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@flrande/bak-protocol": "workspace:*",
    "commander": "^14.0.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0"
  }
}


